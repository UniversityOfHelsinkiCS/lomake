{
  "name": "tilku",
  "version": "1.0.0",
  "description": "Opetushallinnon tilannekuvalomake",
  "type": "module",
  "workspaces": [
    "shared/validators"
  ],
  "scripts": {
    "dev": "docker compose up",
    "dev:build": "docker compose build",
    "build": "vite build",
    "start:prod": "cross-env NODE_ENV=production node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm server/index.ts",
    "start:dev": "cross-env NODE_ENV=development concurrently \"nodemon --exec node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm server/index.ts\" \"vite\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cypress:open": "cypress open --e2e",
    "cypress:run": "cypress run --headless --browser chrome",
    "translations": "node ./scripts/analyzeTranslations.js",
    "seed": "cross-env NODE_ENV=development node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm server/index.ts seed",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/x-date-pickers": "8.2.0",
    "@reduxjs/toolkit": "2.5.0",
    "@sentry/browser": "8.55.0",
    "@sentry/node": "8.55.0",
    "@sentry/tracing": "7.120.3",
    "@sentry/vite-plugin": "2.23.0",
    "@uiw/react-md-editor": "4.0.4",
    "@vitejs/plugin-react-swc": "4.0.0",
    "axios": "1.13.5",
    "compression": "1.8.1",
    "cookie-parser": "1.4.6",
    "date-fns": "4.0.0",
    "dotenv": "16.0.0",
    "draft-js": "0.11.7",
    "esbuild-sass-plugin": "3.2.0",
    "esm": "3.2.25",
    "express": "4.20.0",
    "express-async-errors": "3.1.1",
    "highcharts": "12.5.0",
    "highcharts-react-official": "3.2.3",
    "i18next": "25.0.0",
    "js-cookie": "3.0.5",
    "jsdom": "26.0.0",
    "lodash": "4.17.23",
    "lru-cache": "11.0.0",
    "markdown-draft-js": "2.2.0",
    "module-alias": "2.2.2",
    "moment": "2.29.4",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "node-cron": "3.0.3",
    "pg": "8.6.0",
    "pg-hstore": "2.3.3",
    "react": "18.3.1",
    "react-csv": "2.2.1",
    "react-datepicker": "8.0.0",
    "react-dom": "18.3.1",
    "react-draft-wysiwyg": "1.15.0",
    "react-i18next": "15.0.0",
    "react-intersection-observer": "9.0.0",
    "react-markdown": "10.0.0",
    "react-minimal-pie-chart": "9.0.0",
    "react-redux": "9.2.0",
    "react-router": "7.6.2",
    "react-to-print": "2.14.12",
    "redux": "5.0.1",
    "redux-thunk": "3.0.0",
    "semantic-ui-react": "2.1.5",
    "sequelize": "6.37.8",
    "socket.io": "4.7.2",
    "socket.io-client": "4.7.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "umzug": "3.3.1",
    "unfuck-spa-shibboleth-session": "5.0.0",
    "uuid": "11.0.0",
    "vite": "7.0.0",
    "vite-plugin-socket-io": "1.0.2",
    "winston": "3.17.0",
    "winston-gelf-transporter": "1.0.2",
    "winston-loki": "6.1.3",
    "xlsx": "0.18.5",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/lodash": "4.17.14",
    "@types/multer": "1.4.12",
    "@types/node": "24.10.1",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "concurrently": "9.0.0",
    "cross-env": "7.0.3",
    "cypress": "15.9.0",
    "eslint": "9.28.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-cypress": "5.1.1",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.4.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "^17.4.0",
    "husky": "9.1.7",
    "immer": "10.1.1",
    "minimist": "1.2.8",
    "nodemon": "3.1.0",
    "prettier": "3.5.3",
    "sequelize-cli": "6.6.5",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.34.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "nodemonConfig": {
    "ignore": [
      "cypress/*",
      "dev/*",
      "client/*",
      "node_modules/*"
    ],
    "watch": [
      "server"
    ],
    "ext": "*.js,*.ts, *.jsx, *.tsx, *.json"
  }
}
